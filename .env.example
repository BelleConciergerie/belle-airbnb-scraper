# Auth (REQUIRED — service crash au boot si absent)
API_KEY=change-me-to-strong-token

# Proxy IPRoyal residentiel (REQUIRED pour scraper Airbnb sans ban)
IPROYAL_USER=your-iproyal-user
IPROYAL_PASS=your-iproyal-pass
IPROYAL_HOST=geo.iproyal.com
IPROYAL_PORT=12321
IPROYAL_COUNTRY=fr
IPROYAL_LIFETIME=30m

# Cache TTL (heures)
CACHE_API_KEY_TTL_HOURS=24
CACHE_CALENDAR_TTL_HOURS=12
CACHE_DETAILS_TTL_HOURS=168
CACHE_MAX_ENTRIES=2000

# Logging
LOG_LEVEL=INFO
